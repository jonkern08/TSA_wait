# Supabase — get these from your project's Settings > API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API keys
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret token to protect the /api/collect endpoint
# Generate any random string, e.g.: openssl rand -hex 32
COLLECT_SECRET=your-random-secret
